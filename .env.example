# 复制本文件为 .env，然后只填写你实际启用的服务配置。

# 本地开发与生成行为
# true 时图片生成走本地 SVG mock，方便无外部模型调试。
USE_MOCK_IMAGES=true
# 提示词评分通过阈值。
PROMPT_PASS_THRESHOLD=6.0
# 视觉评分通过阈值。
VISUAL_PASS_THRESHOLD=8.0
# 图片优化流水线最多迭代次数。
MAX_ITERATIONS=3
# 外部模型请求超时时间，单位秒。
REQUEST_TIMEOUT_SECONDS=60
# 外部模型请求失败后的重试次数。
MODEL_REQUEST_RETRIES=2

# 高成本接口保护，作用于模型列表、参考分析、提示词草稿和图片生成。
# 本地开发可留空 AUTH_REQUIRED；只要设置 API_KEY，系统会自动启用鉴权。
# 生产环境建议 AUTH_REQUIRED=true，并填写 API_KEY。
AUTH_REQUIRED=
# AUTH_REQUIRED=true 时默认关闭公开注册；如确需自助注册，可显式设为 true。
ALLOW_PUBLIC_REGISTRATION=false
# 调用高成本接口时使用的 Bearer Token 或 X-API-Key。
API_KEY=
# 单个调用方在限流窗口内最多请求次数。
RATE_LIMIT_REQUESTS=30
# 限流窗口长度，单位秒。
RATE_LIMIT_WINDOW_SECONDS=60

# OpenAI 兼容接口配置
# 默认 OpenAI API 地址；也可填写兼容 OpenAI 协议的代理地址。
OPENAI_BASE_URL=https://api.openai.com/v1
# 图片模型专用 API 地址；留空则使用 OPENAI_BASE_URL。
OPENAI_IMAGE_BASE_URL=
# 评分/分析模型专用 API 地址；留空则使用 OPENAI_BASE_URL。
OPENAI_EVALUATOR_BASE_URL=
# 提示词改写模型专用 API 地址；留空则使用评分模型地址。
OPENAI_PROMPT_DRAFT_BASE_URL=

# 通用 OpenAI API Key。若下方专用 Key 留空，会使用这个作为兜底。
# API Key 只通过环境变量配置，管理后台不会把密钥写入数据库。
OPENAI_API_KEY=

# 图片生成模型配置。
OPENAI_IMAGE_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-2

# 文本分析、视觉氛围评估模型配置。
OPENAI_EVALUATOR_API_KEY=
OPENAI_EVALUATOR_MODEL=gpt-4.1-mini

# AI 提示词改写/文案草稿模型配置。
OPENAI_PROMPT_DRAFT_MODEL=gpt-5.5
# 管理后台允许保存的模型 Base URL 主机白名单，多个用英文逗号分隔。
# 默认允许 api.openai.com 和当前环境变量中已配置的模型主机。
MODEL_BASE_URL_ALLOWED_HOSTS=

# 图片上传目录和大小限制。
ASSET_UPLOAD_DIR=uploads
ASSET_UPLOAD_MAX_BYTES=8388608

# 本地账号、项目、资产和生成任务持久化。
DATABASE_PATH=data/app.db
SESSION_MAX_AGE_SECONDS=604800
# HTTPS 部署时设为 true；本地 http 开发保持 false。
SECURE_SESSION_COOKIES=false
# 可选管理员初始化；三项必须同时填写，不填写则不自动创建管理员。
ADMIN_USERNAME=
ADMIN_EMAIL=
ADMIN_PASSWORD=

# 视频生成模型配置。USE_MOCK_VIDEOS=true 可在无外部视频模型时调试完整项目流程。
USE_MOCK_VIDEOS=true
VIDEO_BASE_URL=https://api.openai.com/v1
VIDEO_API_KEY=
VIDEO_MODEL=video-generation
VIDEO_GENERATE_ENDPOINT=/videos/generations
